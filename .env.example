# PostgreSQL (Amazon RDS) — Phase 1+
# URL-encode special characters in PASSWORD (e.g. @ → %40). See infra/rds-notes.md.
DATABASE_URL=postgresql://USER:PASSWORD@RDS_ENDPOINT:5432/insurance

# AWS / Bedrock — Phase 4+
# See infra/bedrock/notes.md for live Agent IDs and setup.
AWS_REGION=us-east-1
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=
BEDROCK_FALLBACK_MODEL_ID=amazon.nova-lite-v1:0
# Set true to skip Agent and demo the Converse fallback path
BEDROCK_FORCE_FALLBACK=false

# App
LOG_LEVEL=INFO
DEMO_AUTH_SECRET=change-me-in-local-dev

# Frontend (Vite) — used by frontend/.env
VITE_API_BASE_URL=http://localhost:8000
